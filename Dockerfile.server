FROM rust:1.94 AS builder

WORKDIR /workspace
COPY Cargo.toml Cargo.lock ./
COPY apps ./apps
RUN cargo build -p server --release

FROM debian:bookworm-slim

RUN useradd --create-home --shell /usr/sbin/nologin openrok

WORKDIR /app
COPY --from=builder /workspace/target/release/server /usr/local/bin/openrok-server

USER openrok
EXPOSE 8080

CMD ["openrok-server"]
